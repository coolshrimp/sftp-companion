        },
        {
          "command": "sftpCompanion.renameRemote",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "3_manage@1"
        },
        {
          "command": "sftpCompanion.chmodRemote",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "3_manage@2"
        },
        {
          "command": "sftpCompanion.deleteRemote",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
