{
  "name": "sftp-companion",
  "displayName": "SFTP Companion - SFTP/FTP/FTPS Sync",
  "description": "Visual SFTP/FTP/FTPS sync — account manager, sync-status file trees, compare view, and a transfer queue with real progress",
  "version": "0.9.3",
  "publisher": "coolshrimp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Coolshrimp/sftp-companion.git"
  },
  "bugs": {
    "url": "https://github.com/Coolshrimp/sftp-companion/issues"
  },
  "homepage": "https://github.com/Coolshrimp/sftp-companion#readme",
  "icon": "media/sftp-icon.png",
  "galleryBanner": {
    "color": "#2E1D5B",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "sftp",
    "ftp",
    "ftps",
    "deployment",
    "sync",
    "upload",
    "remote",
    "ssh"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sftpCompanion",
          "title": "SFTP Sync",
          "icon": "media/sftp-activity.svg"
        }
      ]
    },
    "views": {
      "sftpCompanion": [
        {
          "id": "sftpCompanionMain",
          "name": "SFTP Companion",
          "type": "tree",
          "icon": "$(dashboard)"
        },
        {
          "id": "sftpCompanionLocal",
          "name": "Local Sync",
          "type": "tree",
          "icon": "$(folder)"
        },
        {
          "id": "sftpCompanionRemote",
          "name": "Remote Files",
          "type": "tree",
          "icon": "$(cloud)"
        },
        {
          "id": "sftpCompanionQueue",
          "name": "Transfer Queue",
          "type": "tree",
          "icon": "$(sync)",
          "visibility": "collapsed"
        },
        {
          "id": "sftpCompanionLog",
          "name": "Log Feed",
          "type": "tree",
          "icon": "$(output)",
          "visibility": "collapsed"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "sftpCompanionRemote",
        "contents": "No SFTP account configured yet.\n[Manage SFTP Account](command:sftpCompanion.accounts.open)",
        "when": "!sftpCompanion.configured"
      },
      {
        "view": "sftpCompanionRemote",
        "contents": "Not connected to the server.\n[Connect](command:sftpCompanion.connect)",
        "when": "sftpCompanion.configured && !sftpCompanion.connected"
      },
      {
        "view": "sftpCompanionLocal",
        "contents": "Configure an SFTP account to browse and sync a local folder.\n[Manage SFTP Account](command:sftpCompanion.accounts.open)",
        "when": "!sftpCompanion.configured"
      },
      {
        "view": "sftpCompanionQueue",
        "contents": "No transfers yet. Uploads and downloads appear here with retry controls."
      }
    ],
    "commands": [
      {
        "command": "sftpCompanion.accounts.open",
        "title": "Manage SFTP Account",
        "category": "SFTP Companion",
        "icon": "$(account)"
      },
      {
        "command": "sftpCompanion.openConfig",
        "title": "Edit sftp.json",
        "category": "SFTP Companion",
        "icon": "$(json)"
      },
      {
        "command": "sftpCompanion.refreshLocal",
        "title": "Refresh Local Files",
        "category": "SFTP Companion",
        "icon": "$(refresh)"
      },
      {
        "command": "sftpCompanion.deleteRemote",
        "title": "Delete from Server…",
        "category": "SFTP Companion",
        "icon": "$(trash)"
      },
      {
        "command": "sftpCompanion.testConnection",
        "title": "Test Connection",
        "category": "SFTP Companion",
        "icon": "$(pulse)"
      },
      {
        "command": "sftpCompanion.setAutoSyncMode",
        "title": "Set Auto Sync Mode",
        "category": "SFTP Companion",
        "icon": "$(sync)"
      },
      {
        "command": "sftpCompanion.accounts.generateConfig",
        "title": "Generate / Update sftp.json",
        "category": "SFTP Companion",
        "icon": "$(new-file)"
      },
      {
        "command": "sftpCompanion.connect",
        "title": "Connect",
        "category": "SFTP Companion",
        "icon": "$(plug)"
      },
      {
        "command": "sftpCompanion.disconnect",
        "title": "Disconnect",
        "category": "SFTP Companion",
        "icon": "$(debug-disconnect)"
      },
      {
        "command": "sftpCompanion.refreshRemote",
        "title": "Refresh Remote Files",
        "category": "SFTP Companion",
        "icon": "$(refresh)"
      },
      {
        "command": "sftpCompanion.revealSyncFolder",
        "title": "Reveal Sync Folder",
        "category": "SFTP Companion",
        "icon": "$(folder-opened)"
      },
      {
        "command": "sftpCompanion.toggleWhitelistTag",
        "title": "Add / Remove from Sync List",
        "category": "SFTP Companion",
        "icon": "$(pin)"
      },
      {
        "command": "sftpCompanion.toggleIgnore",
        "title": "Ignore / Un-ignore (Exclude from Sync)",
        "category": "SFTP Companion",
        "icon": "$(eye-closed)"
      },
      {
        "command": "sftpCompanion.openSyncCenter",
        "title": "Open Sync Center",
        "category": "SFTP Companion",
        "icon": "$(checklist)"
      },
      {
        "command": "sftpCompanion.openSetupGuide",
        "title": "Open Setup Guide",
        "category": "SFTP Companion",
        "icon": "$(book)"
      },
      {
        "command": "sftpCompanion.switchProfile",
        "title": "Switch Server Profile",
        "category": "SFTP Companion",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "sftpCompanion.renameRemote",
        "title": "Rename / Move on Server…",
        "category": "SFTP Companion",
        "icon": "$(edit)"
      },
      {
        "command": "sftpCompanion.newRemoteFile",
        "title": "New File on Server…",
        "category": "SFTP Companion",
        "icon": "$(new-file)"
      },
      {
        "command": "sftpCompanion.newRemoteFolder",
        "title": "New Folder on Server…",
        "category": "SFTP Companion",
        "icon": "$(new-folder)"
      },
      {
        "command": "sftpCompanion.chmodRemote",
        "title": "Change Permissions (chmod)…",
        "category": "SFTP Companion",
        "icon": "$(shield)"
      },
      {
        "command": "sftpCompanion.pauseQueueItem",
        "title": "Pause Transfer",
        "category": "SFTP Companion",
        "icon": "$(debug-pause)"
      },
      {
        "command": "sftpCompanion.stopQueueItem",
        "title": "Stop Transfer",
        "category": "SFTP Companion",
        "icon": "$(debug-stop)"
      },
      {
        "command": "sftpCompanion.resumeQueueItem",
        "title": "Resume Transfer",
        "category": "SFTP Companion",
        "icon": "$(debug-start)"
      },
      {
        "command": "sftpCompanion.pauseQueue",
        "title": "Pause Transfer Queue",
        "category": "SFTP Companion",
        "icon": "$(debug-pause)"
      },
      {
        "command": "sftpCompanion.resumeQueue",
        "title": "Resume Transfer Queue",
        "category": "SFTP Companion",
        "icon": "$(debug-start)"
      },
      {
        "command": "sftpCompanion.uploadFile",
        "title": "Upload to Server",
        "category": "SFTP Companion",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "sftpCompanion.uploadFolder",
        "title": "Upload Folder to Server",
        "category": "SFTP Companion",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "sftpCompanion.downloadFile",
        "title": "Download from Server",
        "category": "SFTP Companion",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sftpCompanion.downloadFolder",
        "title": "Download Folder from Server",
        "category": "SFTP Companion",
        "icon": "$(cloud-download)"
      },
      {
        "command": "sftpCompanion.compareFile",
        "title": "Compare Local ↔ Remote",
        "category": "SFTP Companion",
        "icon": "$(diff)"
      },
      {
        "command": "sftpCompanion.syncResource",
        "title": "Smart Sync (Compare & Choose)",
        "category": "SFTP Companion",
        "icon": "$(sync)"
      },
      {
        "command": "sftpCompanion.openRemoteFile",
        "title": "Open Remote File for Edit",
        "category": "SFTP Companion",
        "icon": "$(edit)"
      },
      {
        "command": "sftpCompanion.retryQueueItem",
        "title": "Retry Transfer",
        "category": "SFTP Companion",
        "icon": "$(debug-restart)"
      },
      {
        "command": "sftpCompanion.removeQueueItem",
        "title": "Remove from Queue",
        "category": "SFTP Companion",
        "icon": "$(trash)"
      },
      {
        "command": "sftpCompanion.clearCompletedTransfers",
        "title": "Clear Completed Transfers",
        "category": "SFTP Companion",
        "icon": "$(clear-all)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "sftpCompanion.accounts.open",
          "when": "view == sftpCompanionMain",
          "group": "navigation@1"
        },
        {
          "command": "sftpCompanion.openSetupGuide",
          "when": "view == sftpCompanionMain",
          "group": "navigation@2"
        },
        {
          "command": "sftpCompanion.connect",
          "when": "view == sftpCompanionRemote",
          "group": "navigation@1"
        },
        {
          "command": "sftpCompanion.disconnect",
          "when": "view == sftpCompanionRemote",
          "group": "navigation@2"
        },
        {
          "command": "sftpCompanion.refreshRemote",
          "when": "view == sftpCompanionRemote",
          "group": "navigation@3"
        },
        {
          "command": "sftpCompanion.refreshLocal",
          "when": "view == sftpCompanionLocal",
          "group": "navigation@1"
        },
        {
          "command": "sftpCompanion.revealSyncFolder",
          "when": "view == sftpCompanionLocal",
          "group": "navigation@2"
        },
        {
          "command": "sftpCompanion.openSyncCenter",
          "when": "view == sftpCompanionQueue",
          "group": "navigation@1"
        },
        {
          "command": "sftpCompanion.pauseQueue",
          "when": "view == sftpCompanionQueue && !sftpCompanion.queuePaused",
          "group": "navigation@2"
        },
        {
          "command": "sftpCompanion.resumeQueue",
          "when": "view == sftpCompanionQueue && sftpCompanion.queuePaused",
          "group": "navigation@2"
        },
        {
          "command": "sftpCompanion.clearCompletedTransfers",
          "when": "view == sftpCompanionQueue",
          "group": "navigation@3"
        },
        {
          "command": "sftpCompanion.openSyncCenter",
          "when": "view == sftpCompanionMain",
          "group": "navigation@0"
        }
      ],
      "view/item/context": [
        {
          "command": "sftpCompanion.connect",
          "when": "view == sftpCompanionMain && viewItem == main-connection-off",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.disconnect",
          "when": "view == sftpCompanionMain && viewItem == main-connection-on",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.testConnection",
          "when": "view == sftpCompanionMain && viewItem =~ /main-connection/",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.openConfig",
          "when": "view == sftpCompanionMain && viewItem == main-account",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.accounts.generateConfig",
          "when": "view == sftpCompanionMain && viewItem == main-account",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.switchProfile",
          "when": "view == sftpCompanionMain && viewItem == main-account",
          "group": "inline@3"
        },
        {
          "command": "sftpCompanion.setAutoSyncMode",
          "when": "view == sftpCompanionMain && viewItem == main-autosync",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.uploadFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.downloadFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "inline@3"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "inline@4"
        },
        {
          "command": "sftpCompanion.uploadFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "1_transfer@1"
        },
        {
          "command": "sftpCompanion.downloadFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "1_transfer@2"
        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "1_transfer@3"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "1_transfer@4"
        },
        {
          "command": "sftpCompanion.toggleWhitelistTag",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "2_autosync@1"
        },
        {
          "command": "sftpCompanion.toggleIgnore",
          "when": "view == sftpCompanionLocal && viewItem == file",
          "group": "2_autosync@2"
        },
        {
          "command": "sftpCompanion.uploadFolder",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.downloadFolder",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.toggleWhitelistTag",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "inline@3"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "inline@4"
        },
        {
          "command": "sftpCompanion.uploadFolder",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "1_transfer@1"
        },
        {
          "command": "sftpCompanion.downloadFolder",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "1_transfer@2"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "1_transfer@3"
        },
        {
          "command": "sftpCompanion.toggleWhitelistTag",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "2_autosync@1"
        },
        {
          "command": "sftpCompanion.toggleIgnore",
          "when": "view == sftpCompanionLocal && viewItem == folder",
          "group": "2_autosync@2"
        },
        {
          "command": "sftpCompanion.downloadFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.uploadFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
