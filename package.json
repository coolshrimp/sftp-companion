      "explorer/context": [
        {
          "command": "sftpCompanion.uploadFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "7_sftpcompanion@1"
        },
        {
          "command": "sftpCompanion.uploadFolder",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "7_sftpcompanion@1"
        },
        {
          "command": "sftpCompanion.downloadFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "7_sftpcompanion@2"
        },
        {
          "command": "sftpCompanion.downloadFolder",
          "when": "resourceScheme == file && explorerResourceIsFolder",
          "group": "7_sftpcompanion@2"
        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "resourceScheme == file && !explorerResourceIsFolder",
          "group": "7_sftpcompanion@3"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@4"
        },
        {
          "command": "sftpCompanion.toggleWhitelistTag",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@5"
        },
        {
          "command": "sftpCompanion.toggleIgnore",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@6"
        }
      ],
      "editor/title/context": [
        {
          "command": "sftpCompanion.uploadFile",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@1"
        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@2"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "resourceScheme == file",
          "group": "7_sftpcompanion@3"
        }
      ],
      "commandPalette": [
        {
          "command": "sftpCompanion.deleteRemote",
          "when": "false"
        },
        {
          "command": "sftpCompanion.renameRemote",
          "when": "false"
        },
        {
          "command": "sftpCompanion.chmodRemote",
          "when": "false"
        },
        {
          "command": "sftpCompanion.retryQueueItem",
          "when": "false"
        },
        {
          "command": "sftpCompanion.removeQueueItem",
          "when": "false"
        },
        {
          "command": "sftpCompanion.pauseQueueItem",
          "when": "false"
        },
        {
          "command": "sftpCompanion.stopQueueItem",
          "when": "false"
        },
        {
          "command": "sftpCompanion.resumeQueueItem",
          "when": "false"
        },
        {
          "command": "sftpCompanion.openRemoteFile",
          "when": "false"
        },
        {
          "command": "sftpCompanion.uploadFolder",
          "when": "false"
        },
        {
          "command": "sftpCompanion.downloadFolder",
          "when": "false"
        }
      ]
    },
    "configuration": {
      "title": "SFTP Companion",
      "properties": {
        "sftpCompanion.autoDeleteRemote": {
          "type": "boolean",
          "default": false,
          "description": "DANGEROUS: when auto-sync is active and a local file or folder inside the synced scope is deleted, also delete it from the server. Folder deletion is recursive and includes ignored or remote-only descendants. Off by default."
        },
        "sftpCompanion.confirmRemoteDelete": {
          "type": "boolean",
          "default": true,
          "description": "Ask for confirmation before deleting files or folders from the server."
        },
        "sftpCompanion.transferConcurrency": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "maximum": 10,
          "description": "How many files transfer at the same time. Each parallel transfer uses its own server connection — lower this if your host limits simultaneous FTP/SFTP sessions. Applies immediately."
        },
        "sftpCompanion.tempRemoteCachePath": {
          "type": "string",
          "default": ".vscode/.sftp-companion-cache",
          "description": "Relative workspace folder used for cached remote files during compare operations."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run check-types && npm run bundle",
    "check-types": "tsc -p ./ --noEmit",
    "bundle": "esbuild src/extension.ts --bundle --platform=node --target=node18 --format=cjs --outfile=dist/extension.js --external:vscode --external:cpu-features --external:*.node --minify",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --allow-missing-repository",
    "install-local": "powershell -Command \"$vsix=(Get-ChildItem *.vsix | Sort-Object LastWriteTime -Descending | Select-Object -First 1); if (-not $vsix) { throw 'No VSIX file found. Run npm run package first.' }; code --install-extension $vsix.FullName --force\"",
    "deploy": "powershell -Command \"npm run package; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; npm run install-local\"",
    "watch:deploy": "chokidar \"src/**/*\" \"media/**/*\" \"package.json\" \"tsconfig.json\" -c \"npm run deploy\" --initial --debounce 1000"
  },
  "dependencies": {
    "basic-ftp": "^6.0.1",
    "minimatch": "^10.1.1",
    "ssh2-sftp-client": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.15",
    "@types/ssh2-sftp-client": "^9.0.6",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.32.0",
    "chokidar-cli": "^3.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.6.3"
  }
}
