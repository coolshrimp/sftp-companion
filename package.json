        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "inline@3"
        },
        {
          "command": "sftpCompanion.openRemoteFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "inline@4"
        },
        {
          "command": "sftpCompanion.openRemoteFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "1_transfer@1"
        },
        {
          "command": "sftpCompanion.downloadFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "1_transfer@2"
        },
        {
          "command": "sftpCompanion.uploadFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "1_transfer@3"
        },
        {
          "command": "sftpCompanion.compareFile",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
          "group": "1_transfer@4"
        },
        {
          "command": "sftpCompanion.syncResource",
          "when": "view == sftpCompanionRemote && viewItem == remote-file",
