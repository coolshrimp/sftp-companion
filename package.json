          "group": "3_manage@4"
        },
        {
          "command": "sftpCompanion.deleteRemote",
          "when": "view == sftpCompanionRemote && viewItem == remote-folder",
          "group": "4_danger@1"
        },
        {
          "command": "sftpCompanion.retryQueueItem",
          "when": "view == sftpCompanionQueue && viewItem == transfer-failed",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.pauseQueueItem",
          "when": "view == sftpCompanionQueue && viewItem == transfer-queued",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.stopQueueItem",
          "when": "view == sftpCompanionQueue && viewItem == transfer-running",
          "group": "inline@2"
        },
        {
          "command": "sftpCompanion.resumeQueueItem",
          "when": "view == sftpCompanionQueue && viewItem == transfer-held",
          "group": "inline@3"
        },
        {
          "command": "sftpCompanion.removeQueueItem",
          "when": "view == sftpCompanionQueue && viewItem != transfer-running",
          "group": "inline@4"
        }
