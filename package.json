        },
        {
          "command": "sftpCompanion.downloadFolder",
          "when": "view == sftpCompanionRemote && viewItem == remote-folder",
          "group": "inline@1"
        },
        {
          "command": "sftpCompanion.uploadFolder",
          "when": "view == sftpCompanionRemote && viewItem == remote-folder",
